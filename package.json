{
  "name": "browser-agent",
  "version": "1.0.0",
  "description": "AI-powered browser agent for course completion",
  "main": "main.js",
  "bin": {
    "browser-agent": "main.js",
    "agent": "main.js"
  },
  "type": "module",
  "scripts": {
    "build": "tsc",
    "build:exe": "pkg main.js --out-path dist --targets node18-win-x64",
    "build:bundle": "ncc build main.js -o dist/bundle",
    "build:all": "npm run build && npm run build:bundle",
    "build:release": "npm run build:all && echo 'Ready for distribution: browser-agent-tool.zip'",
    "start": "node main.js",
    "dev": "ts-node src/index.ts",
    "dev:watch": "ts-node --watch src/index.ts",
    "test": "vitest",
    "test:setup": "node test-setup.js"
  },
  "keywords": ["ai", "browser", "automation", "playwright", "course"],
  "author": "",
  "license": "MIT",
  "dependencies": {
    "better-sqlite3": "^9.2.2",
    "chalk": "^5.3.0",
    "commander": "^11.1.0",
    "dotenv": "^16.3.1",
    "inquirer": "^9.2.12",
    "js-yaml": "^4.1.0",
    "openai": "^4.52.7",
    "pino": "^8.17.2",
    "playwright": "^1.40.1",
    "zod": "^3.22.4"
  },
  "devDependencies": {
    "@types/better-sqlite3": "^7.6.8",
    "@types/inquirer": "^9.0.7",
    "@types/js-yaml": "^4.0.9",
    "@types/node": "^20.10.6",
    "@vercel/ncc": "^0.38.1",
    "pkg": "^5.8.1",
    "ts-node": "^10.9.2",
    "typescript": "^5.3.3",
    "vitest": "^1.1.0"
  },
  "pkg": {
    "scripts": "dist/**/*.js",
    "assets": [
      "config/**/*",
      "prompts/**/*",
      "data/**/*"
    ],
    "outputPath": "dist"
  }
}
